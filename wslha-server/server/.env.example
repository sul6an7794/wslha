PORT=3001

# ملف بيانات محتوى وصّلها المحلي (جولات/صور فقط بعد فصل الحسابات — لا مستخدمين ولا تذاكر هنا).
WSL_DATA_PATH=./data.json

# للتخزين الدائم: ضع رابط اتصال MongoDB Atlas هنا. نفس الرابط يُستخدم من حسابات المنصة
# (users/credit_log) بمجموعات منفصلة — آمن، بلا تصادم.
# لو تُرك فاضيًا، يستخدم السيرفر ملف data.json محلي (مؤقت — يختفي عند إعادة النشر).
# مثال: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/teamquest?retryWrites=true&w=majority
MONGODB_URI=
