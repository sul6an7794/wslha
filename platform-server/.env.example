PORT=3000
ALLOWED_ORIGIN=https://your-domain.example
# نفس رابط MongoDB يُستخدم من طبقتين مستقلتين: حسابات المنصة (users/credit_log) هنا،
# ومحتوى لعبة وصّلها (rounds/round_images/images) في سيرفرها الخاص — مجموعات منفصلة بنفس القاعدة، آمن.
MONGODB_URI=mongodb+srv://...
# مسار ملف بيانات الحسابات المحلي (يُستخدم فقط لو MONGODB_URI فاضي) — مستخدمين/تذاكر فقط،
# ليس بيانات لعبة وصّلها (لها ملف/مجموعة منفصلة بالكامل، تبقى حتى لو انحذفت هذي).
ACCOUNTS_DATA_PATH=./data/accounts.json
JWT_SECRET=replace-with-a-long-random-secret
# مفتاح Authentica لإرسال/التحقق من رمز OTP عبر الجوال (بدل كلمة المرور القديمة).
AUTHENTICA_API_KEY=replace-with-your-authentica-api-key
# اختياري — غيّره فقط لو Authentica زوّدتك برابط مختلف (بيئة تجريبية مثلًا).
# AUTHENTICA_BASE_URL=https://api.authentica.sa
# لا يمنح أي تسجيل عادي صلاحية مشرف. استخدم القيمتين معًا لإنشاء أول مشرف مرة واحدة.
ADMIN_BOOTSTRAP_USERNAME=owner
ADMIN_BOOTSTRAP_TOKEN=replace-with-a-long-random-secret
